<OCRDATASET>
<PAGE IMAGENAME="digidepo_2531162_0024.jpg" WIDTH="2048" HEIGHT="1446">
  <TEXTBLOCK CONF="0.975">
    <LINE TYPE="タイトル本文" X="380" Y="229" WIDTH="189" HEIGHT="22" CONF="0.856" PRED_CHAR_CNT="0.000" ORDER="1" STRING="(2)気送子送付管" />
  <LINE TYPE="本文" X="432" Y="262" WIDTH="558" HEIGHT="32" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="2" STRING="気送子送付には、上記気送管にて送付するものと、空" />
    <LINE TYPE="本文" X="411" Y="307" WIDTH="578" HEIGHT="30" CONF="0.944" PRED_CHAR_CNT="0.000" ORDER="3" STRING="気の圧縮を使用せず.直接落下させる装置の二通りがあ" />
    <LINE TYPE="本文" X="412" Y="352" WIDTH="559" HEIGHT="28" CONF="0.945" PRED_CHAR_CNT="0.000" ORDER="4" STRING="る。後者の送付電は出納台左側に設置されており.5." />
    <LINE TYPE="本文" X="416" Y="389" WIDTH="580" HEIGHT="33" CONF="0.947" PRED_CHAR_CNT="0.000" ORDER="5" STRING="3.1の各層ステーションに直接落下するよう3本の管" />
    <LINE TYPE="本文" X="412" Y="438" WIDTH="581" HEIGHT="28" CONF="0.951" PRED_CHAR_CNT="0.000" ORDER="6" STRING="が通じ投入ロのフタに層表示が記されている。取扱いに" />
    <LINE TYPE="本文" X="417" Y="477" WIDTH="580" HEIGHT="32" CONF="0.948" PRED_CHAR_CNT="0.000" ORDER="7" STRING="当っては気送子投入優すみやかにフタを肉め速度を調整" />
    <LINE TYPE="本文" X="417" Y="526" WIDTH="314" HEIGHT="24" CONF="0.929" PRED_CHAR_CNT="0.000" ORDER="8" STRING="する必要がある。(図2参照)" />
    <SHAPE><POLYGON POINTS="410,265,410,550,998,550,998,265" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.931">
    <LINE TYPE="キャプション" X="522" Y="610" WIDTH="218" HEIGHT="23" CONF="0.887" PRED_CHAR_CNT="0.000" ORDER="10" STRING="(図2)送付管" />
  <SHAPE><POLYGON POINTS="522,610,522,633,740,633,740,610" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.531">
    <LINE TYPE="本文" X="1152" Y="224" WIDTH="623" HEIGHT="25" CONF="0.916" PRED_CHAR_CNT="0.000" ORDER="11" STRING="b各ステーション(以下5.3.1ご現在係員の特徴する層" />
    <LINE TYPE="タイトル本文" X="1171" Y="270" WIDTH="271" HEIGHT="17" CONF="0.753" PRED_CHAR_CNT="0.000" ORDER="13" STRING="のみステーションと呼ぶ)" />
    <LINE TYPE="タイトル本文" X="1164" Y="309" WIDTH="117" HEIGHT="18" CONF="0.913" PRED_CHAR_CNT="0.000" ORDER="15" STRING="(1)気送管" />
    <SHAPE><POLYGON POINTS="1151,223,1151,250,1775,250,1775,223" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.955">
    <LINE TYPE="本文" X="1214" Y="354" WIDTH="559" HEIGHT="25" CONF="0.940" PRED_CHAR_CNT="0.000" ORDER="16" STRING="気送子走行中(赤ランプ点灯)でないとき、目的層の" />
    <LINE TYPE="本文" X="1191" Y="395" WIDTH="567" HEIGHT="26" CONF="0.940" PRED_CHAR_CNT="0.000" ORDER="17" STRING="ボタンを押すと青、赤のランプが同時に点灯するから," />
    <LINE TYPE="本文" X="1189" Y="440" WIDTH="581" HEIGHT="24" CONF="0.942" PRED_CHAR_CNT="0.000" ORDER="18" STRING="投入口の扉を開いて気送子を投入する。気送子が到着す" />
    <LINE TYPE="本文" X="1194" Y="482" WIDTH="306" HEIGHT="21" CONF="0.936" PRED_CHAR_CNT="0.000" ORDER="19" STRING="ると両ランプが同時に消える。" />
    <LINE TYPE="タイトル本文" X="1159" Y="524" WIDTH="191" HEIGHT="18" CONF="0.896" PRED_CHAR_CNT="0.000" ORDER="20" STRING="(2)景送子送子管" />
  <SHAPE><POLYGON POINTS="1189,355,1189,502,1771,502,1771,355" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.953">
    <LINE TYPE="本文" X="1210" Y="567" WIDTH="560" HEIGHT="24" CONF="0.938" PRED_CHAR_CNT="0.000" ORDER="21" STRING="中央出納台よりの落下による一方交通であるので、各" />
    <LINE TYPE="本文" X="1189" Y="612" WIDTH="580" HEIGHT="24" CONF="0.936" PRED_CHAR_CNT="0.000" ORDER="22" STRING="ステーションは受けー方である。従って気送子の返却は" />
    <LINE TYPE="本文" X="1185" Y="653" WIDTH="145" HEIGHT="19" CONF="0.919" PRED_CHAR_CNT="0.000" ORDER="23" STRING="気送管による。" />
  <SHAPE><POLYGON POINTS="1185,567,1185,672,1772,672,1772,567" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.978">
    <LINE TYPE="タイトル本文" X="1144" Y="696" WIDTH="106" HEIGHT="18" CONF="0.915" PRED_CHAR_CNT="0.000" ORDER="24" STRING="C気送子" />
  <LINE TYPE="本文" X="1185" Y="742" WIDTH="576" HEIGHT="22" CONF="0.940" PRED_CHAR_CNT="0.000" ORDER="25" STRING="プラスチックの透明な円筒形で出来ており,頭部はフェ" />
    <LINE TYPE="本文" X="1161" Y="782" WIDTH="605" HEIGHT="25" CONF="0.937" PRED_CHAR_CNT="0.000" ORDER="26" STRING="ルトで保護され,図書請求票を中に入れ(たて二つ折りに" />
    <LINE TYPE="本文" X="1159" Y="825" WIDTH="606" HEIGHT="26" CONF="0.940" PRED_CHAR_CNT="0.000" ORDER="27" STRING="入れる)皮ブタのホックを閉めてから矢印の方向に頭部" />
    <LINE TYPE="本文" X="1163" Y="871" WIDTH="260" HEIGHT="18" CONF="0.929" PRED_CHAR_CNT="0.000" ORDER="28" STRING="を必ず下にして投入する。" />
    <SHAPE><POLYGON POINTS="1158,742,1158,890,1767,890,1767,742" /></SHAPE>
    </TEXTBLOCK>
