<OCRDATASET>
<PAGE IMAGENAME="digidepo_11048278_po_geppo1803_00021.jpg" WIDTH="827" HEIGHT="1170">
  <TEXTBLOCK CONF="0.989">
    <LINE TYPE="本文" X="698" Y="154" WIDTH="13" HEIGHT="275" CONF="0.931" PRED_CHAR_CNT="0.000" ORDER="0" STRING="はじめまして!私は2017年4月に就職後、次" />
    <LINE TYPE="本文" X="673" Y="142" WIDTH="12" HEIGHT="287" CONF="0.934" PRED_CHAR_CNT="0.000" ORDER="1" STRING="世代システム開発研究室(次世代室)という場所で仕" />
    <LINE TYPE="本文" X="647" Y="142" WIDTH="12" HEIGHT="287" CONF="0.929" PRED_CHAR_CNT="0.000" ORDER="2" STRING="事をしています。でも、「次世代室」って何をすると" />
  <LINE TYPE="本文" X="621" Y="144" WIDTH="12" HEIGHT="154" CONF="0.934" PRED_CHAR_CNT="0.000" ORDER="3" STRING="ころか想像しにくいですよね。" />
    <LINE TYPE="本文" X="595" Y="154" WIDTH="13" HEIGHT="276" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="4" STRING="次世代室は、図書館の役割がインターネット等の情" />
    <LINE TYPE="本文" X="569" Y="142" WIDTH="13" HEIGHT="287" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="5" STRING="報技術で変化する中、より先進的なサービスを検討し" />
    <LINE TYPE="本文" X="544" Y="143" WIDTH="13" HEIGHT="238" CONF="0.934" PRED_CHAR_CNT="0.000" ORDER="6" STRING="ていくために作られた比較的新しい部署です。" />
    <LINE TYPE="本文" X="518" Y="155" WIDTH="13" HEIGHT="274" CONF="0.938" PRED_CHAR_CNT="0.000" ORDER="7" STRING="現在、次世代室が取り組んでいる仕事には、「書籍" />
    <LINE TYPE="本文" X="492" Y="143" WIDTH="13" HEIGHT="287" CONF="0.941" PRED_CHAR_CNT="0.000" ORDER="8" STRING="以外も含む様々な資料を効率的に検索するための実験" />
    <LINE TYPE="本文" X="467" Y="143" WIDTH="13" HEIGHT="286" CONF="0.941" PRED_CHAR_CNT="0.000" ORDER="9" STRING="システムの開発」、「映像や音声など、もともとデジタ" />
    <LINE TYPE="本文" X="441" Y="144" WIDTH="13" HEIGHT="286" CONF="0.942" PRED_CHAR_CNT="0.000" ORDER="10" STRING="ルの資料を長期的に保存するための調査」、「A-(機" />
    <LINE TYPE="本文" X="416" Y="142" WIDTH="12" HEIGHT="287" CONF="0.942" PRED_CHAR_CNT="0.000" ORDER="11" STRING="械学習)を利用して、デジタル化した資料をより良い" />
    <LINE TYPE="本文" X="390" Y="142" WIDTH="12" HEIGHT="287" CONF="0.940" PRED_CHAR_CNT="0.000" ORDER="12" STRING="形で提供するための研究」、「デジタルアーカイブや研" />
    <LINE TYPE="本文" X="364" Y="142" WIDTH="12" HEIGHT="287" CONF="0.942" PRED_CHAR_CNT="0.000" ORDER="13" STRING="究データの利活用のためのイベント開催」などがあり" />
    <LINE TYPE="本文" X="338" Y="143" WIDTH="13" HEIGHT="286" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="14" STRING="ます。職員だけでは難しい課題や連携が必要な仕事も" />
    <LINE TYPE="本文" X="313" Y="142" WIDTH="12" HEIGHT="287" CONF="0.945" PRED_CHAR_CNT="0.000" ORDER="15" STRING="多いので、テーマに応じて外部の研究者・図書館関係" />
    <LINE TYPE="本文" X="287" Y="141" WIDTH="13" HEIGHT="287" CONF="0.945" PRED_CHAR_CNT="0.000" ORDER="16" STRING="者の皆様や館内の他部署とも協力しながら、「次世代」" />
    <LINE TYPE="本文" X="261" Y="144" WIDTH="13" HEIGHT="143" CONF="0.932" PRED_CHAR_CNT="0.000" ORDER="17" STRING="の図書館を模索しています。" />
    <LINE TYPE="本文" X="235" Y="154" WIDTH="13" HEIGHT="275" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="18" STRING="次世代室の特色の一つとして、外部に委託するだけ" />
    <LINE TYPE="本文" X="210" Y="143" WIDTH="13" HEIGHT="286" CONF="0.944" PRED_CHAR_CNT="0.000" ORDER="19" STRING="でなく、職員自身で開発や実験を行っていることが挙" />
    <LINE TYPE="本文" X="185" Y="141" WIDTH="12" HEIGHT="289" CONF="0.946" PRED_CHAR_CNT="0.000" ORDER="20" STRING="げられます。雰囲気としては静粛な事務室というより" />
    <LINE TYPE="本文" X="158" Y="143" WIDTH="13" HEIGHT="286" CONF="0.946" PRED_CHAR_CNT="0.000" ORDER="21" STRING="も、大学の研究室のようなものを想像して頂ければ分" />
    <LINE TYPE="本文" X="133" Y="143" WIDTH="12" HEIGHT="286" CONF="0.937" PRED_CHAR_CNT="0.000" ORDER="22" STRING="かりやすいかもしれません。例えばある日の会話の内" />
    <SHAPE><POLYGON POINTS="132,142,132,430,711,430,711,142" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.919">
    <LINE TYPE="本文" X="699" Y="462" WIDTH="12" HEIGHT="108" CONF="0.914" PRED_CHAR_CNT="0.000" ORDER="23" STRING="容をご紹介しますと、" />
  <LINE TYPE="本文" X="667" Y="478" WIDTH="12" HEIGHT="270" CONF="0.936" PRED_CHAR_CNT="0.000" ORDER="24" STRING="「ディープラーニングを利用した資料の白色化の実験" />
    <LINE TYPE="本文" X="647" Y="477" WIDTH="12" HEIGHT="132" CONF="0.925" PRED_CHAR_CNT="0.000" ORDER="25" STRING="結果はこんな感じでした。」" />
    <LINE TYPE="本文" X="626" Y="478" WIDTH="12" HEIGHT="270" CONF="0.934" PRED_CHAR_CNT="0.000" ORDER="26" STRING="「なるほど。資料の活字の可読性が上がるようにコント" />
    <LINE TYPE="本文" X="605" Y="478" WIDTH="12" HEIGHT="270" CONF="0.930" PRED_CHAR_CNT="0.000" ORDER="27" STRING="ラスト調整のパラメータを自動で学習してくれるんだ" />
    <LINE TYPE="本文" X="585" Y="478" WIDTH="11" HEIGHT="21" CONF="0.854" PRED_CHAR_CNT="0.000" ORDER="28" STRING="ね。」" />
    <LINE TYPE="本文" X="563" Y="478" WIDTH="12" HEIGHT="270" CONF="0.938" PRED_CHAR_CNT="0.000" ORDER="29" STRING="「国立国会図書館テジタルコレクションから印刷する" />
    <LINE TYPE="本文" X="543" Y="478" WIDTH="11" HEIGHT="175" CONF="0.926" PRED_CHAR_CNT="0.000" ORDER="30" STRING="際にも読みやすくなりそうですね。" />
    <LINE TYPE="本文" X="522" Y="478" WIDTH="12" HEIGHT="270" CONF="0.936" PRED_CHAR_CNT="0.000" ORDER="31" STRING="「OCRの読取精度向上にも使えそうだね。あとはうま" />
    <LINE TYPE="本文" X="501" Y="478" WIDTH="12" HEIGHT="241" CONF="0.925" PRED_CHAR_CNT="0.000" ORDER="32" STRING="くいかなかったケースの条件を再検討しようか。」" />
    <LINE TYPE="本文" X="480" Y="489" WIDTH="11" HEIGHT="120" CONF="0.907" PRED_CHAR_CNT="0.000" ORDER="34" STRING="(以下、議論が続く……)" />
    <SHAPE><POLYGON POINTS="481,477,481,749,680,749,680,477" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.983">
    <LINE TYPE="本文" X="480" Y="489" WIDTH="11" HEIGHT="120" CONF="0.282" PRED_CHAR_CNT="0.000" ORDER="33" STRING="(以下、議論が続く……)" />
  <LINE TYPE="本文" X="441" Y="474" WIDTH="13" HEIGHT="274" CONF="0.941" PRED_CHAR_CNT="0.000" ORDER="35" STRING="配属されてから感じた次世代室の業務の面白さとし" />
    <LINE TYPE="本文" X="415" Y="464" WIDTH="13" HEIGHT="283" CONF="0.945" PRED_CHAR_CNT="0.000" ORDER="36" STRING="て、研究者の方と接する機会も多く、最新の技術につ" />
    <LINE TYPE="本文" X="390" Y="464" WIDTH="12" HEIGHT="284" CONF="0.939" PRED_CHAR_CNT="0.000" ORDER="37" STRING="いて学ぶことができること、学会に参加したり論文を" />
    <LINE TYPE="本文" X="364" Y="462" WIDTH="12" HEIGHT="286" CONF="0.944" PRED_CHAR_CNT="0.000" ORDER="38" STRING="調べたり報告を書いたりといった仕事があること、希" />
    <LINE TYPE="本文" X="338" Y="462" WIDTH="13" HEIGHT="286" CONF="0.942" PRED_CHAR_CNT="0.000" ORDER="39" STRING="望すれば自分でプログラムを書いて新しいサービスを" />
    <LINE TYPE="本文" X="313" Y="462" WIDTH="12" HEIGHT="286" CONF="0.939" PRED_CHAR_CNT="0.000" ORDER="40" STRING="模索できることなどが挙げられます。一方で新人職員" />
    <LINE TYPE="本文" X="287" Y="463" WIDTH="13" HEIGHT="285" CONF="0.943" PRED_CHAR_CNT="0.000" ORDER="41" STRING="として、新しく勉強しなければならない業務知識は多" />
    <LINE TYPE="本文" X="261" Y="463" WIDTH="13" HEIGHT="285" CONF="0.939" PRED_CHAR_CNT="0.000" ORDER="42" STRING="く、周囲の上司や先輩職員にいつも助けて頂く日々で" />
    <LINE TYPE="本文" X="237" Y="462" WIDTH="11" HEIGHT="15" CONF="0.852" PRED_CHAR_CNT="0.000" ORDER="43" STRING="す。" />
    <LINE TYPE="本文" X="210" Y="474" WIDTH="12" HEIGHT="274" CONF="0.944" PRED_CHAR_CNT="0.000" ORDER="44" STRING="早く一人前になれるよう、また自分の仕事が多くの" />
    <LINE TYPE="本文" X="184" Y="462" WIDTH="13" HEIGHT="286" CONF="0.946" PRED_CHAR_CNT="0.000" ORDER="45" STRING="人の役に立つよう、めげずに常に好奇心を持って精進" />
    <LINE TYPE="本文" X="159" Y="463" WIDTH="11" HEIGHT="120" CONF="0.928" PRED_CHAR_CNT="0.000" ORDER="46" STRING="して参ろうと思います。" />
    <LINE TYPE="本文" X="133" Y="462" WIDTH="12" HEIGHT="281" CONF="0.939" PRED_CHAR_CNT="0.000" ORDER="47" STRING="(電子情報サービス課次世代システム開発研究室青蛙)" />
    <SHAPE><POLYGON POINTS="132,462,132,749,454,749,454,462" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.918">
    <LINE TYPE="本文" X="179" Y="825" WIDTH="205" HEIGHT="12" CONF="0.869" PRED_CHAR_CNT="0.000" ORDER="48" STRING="画像に対して機械学習を適用した実験" />
  <LINE TYPE="本文" X="191" Y="842" WIDTH="182" HEIGHT="12" CONF="0.870" PRED_CHAR_CNT="0.000" ORDER="49" STRING="背景白色化による紙の変色の除去" />
    <SHAPE><POLYGON POINTS="178,825,178,854,384,854,384,825" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.858">
    <LINE TYPE="本文" X="441" Y="794" WIDTH="252" HEIGHT="40" CONF="0.483" PRED_CHAR_CNT="0.000" ORDER="50" STRING="び世代室の謎に迫れ、" />
    <SHAPE><POLYGON POINTS="441,794,441,834,693,834,693,794" /></SHAPE>
    </TEXTBLOCK>
  <TEXTBLOCK CONF="0.269">
    <LINE TYPE="本文" X="547" Y="968" WIDTH="45" HEIGHT="21" CONF="0.277" PRED_CHAR_CNT="0.000" ORDER="53" STRING="館内" />
  <LINE TYPE="タイトル本文" X="552" Y="989" WIDTH="128" HEIGHT="30" CONF="0.500" PRED_CHAR_CNT="0.000" ORDER="55" STRING="スコース員" />
    <SHAPE><POLYGON POINTS="547,941,547,994,683,994,683,941" /></SHAPE>
    </TEXTBLOCK>
    <LINE TYPE="本文" X="425" Y="879" WIDTH="11" HEIGHT="159" CONF="0.441" PRED_CHAR_CNT="0.000" ORDER="56" STRING="だり--若くば期待さへ-した" />
    <LINE TYPE="本文" X="405" Y="879" WIDTH="11" HEIGHT="160" CONF="0.447" PRED_CHAR_CNT="0.000" ORDER="57" STRING="から歸つてまもなく、グスハウス通" />
    <LINE TYPE="本文" X="385" Y="878" WIDTH="12" HEIGHT="161" CONF="0.364" PRED_CHAR_CNT="0.000" ORDER="58" STRING="ハィルディドハィルデに出會つた。馬鹿々々しい" />
    <LINE TYPE="本文" X="364" Y="878" WIDTH="12" HEIGHT="161" CONF="0.357" PRED_CHAR_CNT="0.000" ORDER="59" STRING="のである。それは、それには、それになつてゐた。彼" />
